DATABASE_URL=postgresql+psycopg://flashsupport_auth:flashsupport_auth@auth-db:5432/flashsupport_auth
DATABASE_ENCRYPTION_KEY=replace_me_with_random_32_chars_minimum
AUTH_PRIVATE_KEY_PATH=config/keys/auth/private.pem
AUTH_PUBLIC_KEY_PATH=config/keys/auth/public.pem
SERVICE_PUBLIC_KEYS_DIR=config/keys/services
TOKEN_ISSUER=flashsupport-auth-service
USER_ACCESS_TOKEN_AUDIENCE=flashsupport-services
SERVICE_ASSERTION_AUDIENCE=auth-service
USER_ACCESS_TOKEN_TTL_MINUTES=15
USER_REFRESH_TOKEN_TTL_DAYS=15
SERVICE_ACCESS_TOKEN_TTL_MINUTES=15
BCRYPT_ROUNDS=12
CLOCK_SKEW_SECONDS=10
SKIP_SCHEMA_INIT=false
